---
// 共享布局:head / meta / OG + 站点 CSS。0.1.0 始发,极简静态。
// locale 决定 <html lang> 与 hreflang 备用链接;内容由各 page 传入(单语言渲染)。
import { LOCALES, localePath, htmlLang, DEFAULT_LOCALE, type Locale } from "../i18n";
const {
  locale = DEFAULT_LOCALE as Locale,
  title = "Aglet — AI workflow tools, local-first",
  description = "Aglet runs aglets — small AI-authored tools, sandboxed, reviewed in public, local-first.",
} = Astro.props;
const site = "https://aglet.dev";
const canonical = site + (localePath[locale as Locale] === "/" ? "/" : localePath[locale as Locale]);
---

<!doctype html>
<html lang={htmlLang[locale as Locale]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {LOCALES.map((l) => (
      <link rel="alternate" hreflang={htmlLang[l]} href={site + (localePath[l] === "/" ? "/" : localePath[l])} />
    ))}
    <link rel="alternate" hreflang="x-default" href={site + "/"} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <style is:global>
      :root {
        --bg: #fafaf9;
        --fg: #18181b;
        --muted: #71717a;
        --line: #e4e4e7;
        --card: #ffffff;
        /* 品牌强调色 = 琥珀(与 app 图标 core 一致)。 */
        --accent: #f97316;
        --code-bg: #f4f4f5;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0b0b0c;
          --fg: #f4f4f5;
          --muted: #a1a1aa;
          --line: #27272a;
          --card: #18181b;
          --code-bg: #1f1f23;
        }
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0; padding: 0;
        background: var(--bg); color: var(--fg);
        font: 16px/1.65 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "PingFang SC", "Hiragino Sans", sans-serif;
      }
      .wrap { max-width: 880px; margin: 0 auto; padding: 64px 24px 96px; }
      .hero { text-align: center; padding: 24px 0 48px; }
      .hero h1 { font-size: clamp(40px, 7vw, 64px); letter-spacing: -0.03em; margin: 0 0 12px; font-weight: 700; }
      .accent { color: var(--accent); }
      .hero .tag { font-size: clamp(16px, 2.2vw, 20px); color: var(--muted); margin: 0 0 36px; }
      .badges { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; margin: 12px 0 0; }
      .badge { display: inline-block; padding: 4px 10px; border: 1px solid var(--line); border-radius: 999px; font-size: 12px; color: var(--muted); }
      .cta { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-top: 20px; }
      .cta a { display: inline-flex; align-items: center; padding: 10px 20px; border-radius: 8px; font-weight: 500; text-decoration: none; transition: opacity .15s, transform .05s; }
      .cta a:active { transform: translateY(1px); }
      .cta .primary { background: var(--accent); color: white; }
      .cta .primary:hover { opacity: .9; }
      .cta .secondary { background: var(--card); color: var(--fg); border: 1px solid var(--line); }
      .cta .secondary:hover { background: var(--code-bg); }
      section { margin-top: 56px; }
      section h2 { font-size: 22px; margin: 0 0 16px; letter-spacing: -0.01em; }
      section .lede { color: var(--muted); margin: 0 0 20px; }
      .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 10px; }
      .grid .item { padding: 12px 14px; background: var(--card); border: 1px solid var(--line); border-radius: 8px; font-size: 14px; }
      .grid .item b { font-weight: 600; }
      .grid .item span { color: var(--muted); display: block; font-size: 12px; margin-top: 2px; }
      pre { background: var(--code-bg); padding: 14px 16px; border-radius: 8px; overflow-x: auto; font-size: 13px; border: 1px solid var(--line); }
      code { background: var(--code-bg); padding: 2px 6px; border-radius: 4px; font-family: "SF Mono", Menlo, Consolas, monospace; font-size: 0.9em; }
      pre code { background: transparent; padding: 0; }
      .pillars { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; }
      .pillars .pillar { background: var(--card); border: 1px solid var(--line); border-radius: 12px; padding: 18px 20px; }
      .pillars .pillar h3 { margin: 0 0 6px; font-size: 16px; }
      .pillars .pillar p { margin: 0; color: var(--muted); font-size: 14px; }
      footer { margin-top: 80px; padding-top: 24px; border-top: 1px solid var(--line); color: var(--muted); font-size: 13px; text-align: center; }
      footer a { color: var(--muted); margin: 0 8px; }
      hr { border: none; border-top: 1px solid var(--line); margin: 80px 0 48px; }
      a { color: var(--accent); }
      /* 语言切换器:右上角,跳到对应 locale 的独立页面 */
      .langbar { display: flex; gap: 4px; justify-content: flex-end; margin: -32px 0 8px; }
      .langbar .lang { font-size: 13px; padding: 4px 10px; border-radius: 999px; text-decoration: none; color: var(--muted); }
      .langbar a.lang:hover { background: var(--code-bg); color: var(--fg); }
      .langbar .lang.active { color: var(--fg); font-weight: 600; }
      h1, h2, h3 { line-height: 1.25; }
      h3.sub { font-size: 16px; margin: 36px 0 12px; }
      /* 提示词复制块 */
      .prompt { position: relative; }
      .prompt pre { margin: 0; white-space: pre-wrap; }
      .prompt .copy-btn {
        position: absolute; top: 10px; right: 10px; z-index: 1;
        font: inherit; font-size: 12px; padding: 5px 12px; cursor: pointer;
        border: 1px solid var(--line); border-radius: 6px;
        background: var(--card); color: var(--fg); transition: opacity .15s, background .15s;
      }
      .prompt .copy-btn:hover { background: var(--bg); }
      .prompt .copy-btn.ok { background: var(--accent); color: #fff; border-color: var(--accent); }
    </style>
  </head>
  <body>
    <div class="wrap">
      <slot />
    </div>
  </body>
</html>
